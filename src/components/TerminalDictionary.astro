---
import { getDictionaryContent } from "@/utils/content";
import TerminalValue from "@components/TerminalValue.astro";

interface Props {
    src: string;
    entry?: string;
}

const { src, entry } = Astro.props;
const rows = await getDictionaryContent(src, entry);
---

<dl class="output-pairs">
    {
        rows.map((row) => (
            <>
                <dt class="output-label">{row.label}</dt>
                <dd class="output-value">
                    <TerminalValue
                        value={row.value}
                        attributes={row.attributes}
                    />
                </dd>
            </>
        ))
    }
</dl>
