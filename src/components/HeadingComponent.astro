---
interface Props {
    level?: 1 | 2 | 3 | 4 | 5 | 6;
    class?: string;
}

const { level = 1, class: className = "" } = Astro.props;

const styles = {
    1: "mx-auto w-fit text-4xl font-bold text-gray-900 mb-4",
    2: "mx-auto w-fit text-3xl font-semibold text-gray-800 mb-3",
    3: "mx-auto w-fit text-2xl font-medium text-gray-700 mb-2",
    4: "mx-auto w-fit text-xl font-medium text-gray-700 mb-2",
    5: "mx-auto w-fit text-lg font-medium text-gray-700 mb-1",
    6: "mx-auto w-fit text-base font-medium text-gray-700 mb-1",
};

const Tag = `h${level}`;
---

<Tag class:list={[className, styles[level]]}>
    <slot />
</Tag>
