---
import { navLists } from "@config/navigation.ts";
import { withBase } from "@/utils/url";

interface Props {
    navList: keyof typeof navLists;
}

const { navList } = Astro.props;
const navItems = navLists[navList];

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const pathname =
    basePath && Astro.url.pathname.startsWith(basePath)
        ? Astro.url.pathname.slice(basePath.length) || "/"
        : Astro.url.pathname;
---

<nav class="site-nav" aria-label={`${navList} navigation`}>
    {
        navItems.map((item) => {
            const isCurrent = item.href === "/" ? pathname === "/" : pathname.startsWith(item.href);

            return (
                <a href={withBase(item.href)} class:list={["nav-link", { "is-current": isCurrent }]}>
                    <span aria-hidden="true">{isCurrent ? ">" : "$"}</span>
                    {item.label}
                </a>
            );
        })
    }
</nav>
