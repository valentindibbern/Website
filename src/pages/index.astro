---
import figlet from "figlet";
import BaseLayout from "@layouts/BaseLayout.astro";
import TerminalBlock from "@components/TerminalBlock.astro";
import {
    createLinksBlock,
    getFirstBlock,
    getProfile,
    getProjects,
    getReferences,
    getSnippets,
} from "@/utils/content";

const title = "Home";
const asciiName = figlet.textSync("Valentin Dibbern", { font: "Big" });
const profile = await getProfile();
const projects = await getProjects();
const references = await getReferences();
const snippets = await getSnippets();
const firstProject = projects[0];
const firstReference = references[0];
const profileBlock = getFirstBlock(profile.data);
const projectBlock = firstProject ? getFirstBlock(firstProject.data) : undefined;
const referenceBlock = firstReference
    ? getFirstBlock(firstReference.data)
    : undefined;
const linksBlock = createLinksBlock(snippets.links);
---

<BaseLayout title={title}>
    <div class="terminal-page home-page">
        <section class="terminal-hero" aria-label="Valentin Dibbern">
            <pre
                class="ascii-logo"
                aria-label="Valentin Dibbern">{asciiName}</pre>

            <p class="prompt">visitor@portfolio:~$ ./introduce.sh</p>
            <p class="terminal-lede">
                {profile.data.role}. {snippets["home.lede"]}
            </p>

        </section>

        <section id="about" class="terminal-section">
            <p class="prompt">visitor@portfolio:~$ cd /about</p>
            <p class="section-intro">
                Der erste Eintrag aus der About-Seite. Die Unterseite ist für
                einen öffentlichen Fliesstext über mich vorbereitet.
            </p>

            <div class="terminal-list">
                {profileBlock && <TerminalBlock path="/about" block={profileBlock} />}
            </div>
        </section>

        <section id="projects" class="terminal-section">
            <p class="prompt">visitor@portfolio:~$ cd /projects</p>
            <p class="section-intro">
                Der erste Projekt-Eintrag aus GitHub. Die vollständige
                Projektliste liegt auf der Projects-Seite.
            </p>

            <div class="terminal-list">
                {projectBlock && <TerminalBlock path="/projects" block={projectBlock} />}
            </div>
        </section>

        <section id="links" class="terminal-section">
            <p class="prompt">visitor@portfolio:~$ cd /links</p>
            <p class="section-intro">
                Der erste Link-Output. Downloads bleiben bewusst deaktiviert;
                hier stehen nur Kontakt- und Profilrouten.
            </p>

            <div class="terminal-list">
                <TerminalBlock path="/links" block={linksBlock} />
            </div>
        </section>

        <section id="references" class="terminal-section">
            <p class="prompt">visitor@portfolio:~$ cd /references</p>
            <p class="section-intro">
                Der erste Referenz-/Nachweis-Eintrag. Dateien sind im Dossier
                vorhanden, werden aber aktuell nicht als Download angeboten.
            </p>

            <div class="terminal-list">
                {
                    referenceBlock && (
                        <TerminalBlock path="/references" block={referenceBlock} />
                    )
                }
            </div>
        </section>

        <p class="cursor" aria-label="Terminal cursor">
            visitor@portfolio:~$ _
        </p>
    </div>
</BaseLayout>
