---
import BaseLayout from "@layouts/BaseLayout.astro";
import TerminalCommand from "@components/TerminalCommand.astro";
import TerminalDictionary from "@components/TerminalDictionary.astro";
import TerminalHeading from "@components/TerminalHeading.astro";
import TerminalText from "@components/TerminalText.astro";
import { getDictionaryEntries } from "@/utils/content";

const title = "Home";
const [firstProject] = await getDictionaryEntries("projects");
---

<BaseLayout title={title}>
    <div class="terminal-page home-page">
        <section class="terminal-hero" aria-label="Valentin Dibbern">
            <TerminalCommand command="echo $HOME" path=""></TerminalCommand>
            <TerminalHeading text="Valentin Dibbern" size="Big" />

            <TerminalCommand command="cat introduction.txt" />
            <div class="terminal-lede">
                <TerminalText src="home-lede" />
            </div>
        </section>

        <section id="home-section-about" class="terminal-section">
            <TerminalCommand command="cd about"></TerminalCommand>
            <TerminalCommand path="/about" command="cat profile.yaml" />
            <div class="terminal-list">
                <article class="terminal-entry">
                    <TerminalDictionary src="profile" />
                </article>
            </div>
        </section>

        <section id="home-section-projects" class="terminal-section">
            <TerminalCommand command="cd ../projects" />
            <div class="terminal-list">
                {
                    firstProject && (
                        <article class="terminal-entry">
                            <TerminalCommand
                                path="/projects"
                                command={firstProject.command ?? "cat projects.yaml"}
                            />
                            <TerminalDictionary src="projects" entry={firstProject.id} />
                        </article>
                    )
                }
            </div>
        </section>

        <section id="home-section-links" class="terminal-section">
            <TerminalCommand path="/links" command="cat links.yaml" />
            <div class="terminal-list">
                <article class="terminal-entry">
                    <TerminalDictionary src="links" />
                </article>
            </div>
        </section>
    </div>
</BaseLayout>
