---
import TerminalCommand from "@components/TerminalCommand.astro";
import TerminalDictionary from "@components/TerminalDictionary.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getDictionaryEntries } from "@/utils/content";

const title = "Projects";
const projects = await getDictionaryEntries("projects");
---

<BaseLayout title={title}>
    <div class="terminal-page terminal-subpage">
        <section
            class="terminal-section first-section"
            aria-labelledby="projects-title"
        >
            <TerminalCommand command="cd /projects" />
            <h1 id="projects-title" class="section-heading">projects/</h1>
            <p class="section-intro">
                Projektübersicht als vertikale Log-Liste. Jede Ausgabe kann
                später zu einer eigenen Projektseite erweitert werden.
            </p>

            <div class="terminal-list">
                {
                    projects.map((entry) => (
                        <article class="terminal-entry">
                            <TerminalCommand
                                path="/projects"
                                command={entry.command ?? "cat projects.yaml"}
                            />
                            <TerminalDictionary src="projects" entry={entry.id} />
                        </article>
                    ))
                }
            </div>
        </section>
    </div>
</BaseLayout>
