---
import TerminalOutput from "@components/TerminalOutput.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
    getProfileContent,
    getSnippets,
    getTerminalEntries,
    toStringList,
} from "@/utils/content";

const title = "About";
const { profile, Content } = await getProfileContent();
const education = await getTerminalEntries("education");
const experience = await getTerminalEntries("experience");
const snippets = await getSnippets();
const skills = toStringList(snippets.skills);
const languages = toStringList(snippets.languages);
const hobbies = toStringList(snippets.hobbies);
---

<BaseLayout title={title}>
    <div class="terminal-page terminal-subpage">
        <section
            class="terminal-section first-section"
            aria-labelledby="about-title"
        >
            <p class="prompt">visitor@portfolio:~$ cd /about</p>
            <h1 id="about-title" class="section-heading">about.md</h1>
            <p class="section-intro">
                {profile.data.intro}
            </p>

            <article class="about-copy">
                <Content />
            </article>
            <p class="input-needed">{snippets["input.aboutText"]}</p>

            <section class="profile-details" aria-label="Profilangaben">
                {profile.data.details.map((entry) => (
                    <dl class="profile-detail">
                        <dt class="profile-detail-label">{entry.label}</dt>
                        <dd class="profile-detail-value">{entry.value}</dd>
                    </dl>
                ))}
            </section>

            <div class="terminal-list">
                <TerminalOutput
                    path="/about"
                    command="cat skills.txt"
                    body={skills.join("\n")}
                />
                {
                    education.map((entry) => (
                        <TerminalOutput
                            path="/about"
                            command={entry.data.command}
                            body={entry.data.body}
                        />
                    ))
                }
                {
                    experience.map((entry) => (
                        <TerminalOutput
                            path="/about"
                            command={entry.data.command}
                            body={entry.data.body}
                        />
                    ))
                }
                <TerminalOutput
                    path="/about"
                    command="cat languages.txt"
                    body={languages.join("\n")}
                />
                <TerminalOutput
                    path="/about"
                    command="cat hobbies.txt"
                    body={hobbies.join("\n")}
                />
            </div>
        </section>
    </div>
</BaseLayout>
