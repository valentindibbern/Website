---
import TerminalTable from "@components/TerminalTable.astro";
import TerminalOutput from "@components/TerminalOutput.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
    getProfileContent,
    getProfileRows,
    getSnippets,
    getTerminalRows,
    getTerminalEntries,
    toSkillList,
    toStringList,
} from "@/utils/content";

const title = "About";
const { profile, Content } = await getProfileContent();
const education = await getTerminalEntries("education");
const experience = await getTerminalEntries("experience");
const snippets = await getSnippets();
const skills = toSkillList(snippets.skills);
const languages = toStringList(snippets.languages);
const hobbies = toStringList(snippets.hobbies);
---

<BaseLayout title={title}>
    <div class="terminal-page terminal-subpage">
        <section
            class="terminal-section first-section"
            aria-labelledby="about-title"
        >
            <p class="prompt">visitor@portfolio:~$ cd /about</p>
            <h1 id="about-title" class="section-heading">about.md</h1>
            <p class="section-intro">
                Diese Seite ist für einen öffentlichen Fliesstext über mich
                vorbereitet. Der aktuelle Text ist ein Platzhalter.
            </p>

            <article class="about-copy">
                <Content />
            </article>
            <p class="input-needed">{snippets["input.aboutText"]}</p>

            <div class="terminal-list">
                <TerminalOutput
                    path="/about"
                    command="cat public-profile.txt"
                    body=""
                    rows={getProfileRows(profile.data, true)}
                />
                <TerminalTable
                    path="/about"
                    command="cat skills.txt"
                    columns={[
                        { key: "name", label: "Name" },
                        { key: "category", label: "Kategorie" },
                    ]}
                    rows={skills}
                />
                {
                    education.map((entry) => (
                        <TerminalOutput
                            path="/about"
                            command={entry.data.command}
                            body=""
                            rows={getTerminalRows(entry.data)}
                        />
                    ))
                }
                {
                    experience.map((entry) => (
                        <TerminalOutput
                            path="/about"
                            command={entry.data.command}
                            body=""
                            rows={getTerminalRows(entry.data)}
                        />
                    ))
                }
                <TerminalOutput
                    path="/about"
                    command="cat languages.txt"
                    body={languages.join("\n")}
                />
                <TerminalOutput
                    path="/about"
                    command="cat hobbies.txt"
                    body={hobbies.join("\n")}
                />
            </div>
        </section>
    </div>
</BaseLayout>
