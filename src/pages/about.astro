---
import TerminalBlock from "@components/TerminalBlock.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
    createListBlock,
    createSkillTableBlock,
    getBlocks,
    getProfileContent,
    getSnippets,
    getTerminalEntries,
} from "@/utils/content";

const title = "About";
const { profile, Content } = await getProfileContent();
const education = await getTerminalEntries("education");
const experience = await getTerminalEntries("experience");
const snippets = await getSnippets();
const profileBlocks = getBlocks(profile.data);
const educationBlocks = education.flatMap((entry) => getBlocks(entry.data));
const experienceBlocks = experience.flatMap((entry) => getBlocks(entry.data));
const skillBlock = createSkillTableBlock(snippets.skills);
const languageBlock = createListBlock(snippets.languages, "cat languages.txt");
const hobbyBlock = createListBlock(snippets.hobbies, "cat hobbies.txt");
---

<BaseLayout title={title}>
    <div class="terminal-page terminal-subpage">
        <section
            class="terminal-section first-section"
            aria-labelledby="about-title"
        >
            <p class="prompt">visitor@portfolio:~$ cd /about</p>
            <h1 id="about-title" class="section-heading">about.md</h1>
            <p class="section-intro">
                Diese Seite ist für einen öffentlichen Fliesstext über mich
                vorbereitet. Der aktuelle Text ist ein Platzhalter.
            </p>

            <article class="about-copy">
                <Content />
            </article>
            <p class="input-needed">{snippets["input.aboutText"]}</p>

            <div class="terminal-list">
                {
                    profileBlocks.map((block) => (
                        <TerminalBlock path="/about" block={block} />
                    ))
                }
                <TerminalBlock path="/about" block={skillBlock} />
                {
                    educationBlocks.map((block) => (
                        <TerminalBlock path="/about" block={block} />
                    ))
                }
                {
                    experienceBlocks.map((block) => (
                        <TerminalBlock path="/about" block={block} />
                    ))
                }
                <TerminalBlock path="/about" block={languageBlock} />
                <TerminalBlock path="/about" block={hobbyBlock} />
            </div>
        </section>
    </div>
</BaseLayout>
