---
import TerminalCommand from "@components/TerminalCommand.astro";
import TerminalDictionary from "@components/TerminalDictionary.astro";
import TerminalHeading from "@components/TerminalHeading.astro";
import TerminalList from "@components/TerminalList.astro";
import TerminalTable from "@components/TerminalTable.astro";
import TerminalText from "@components/TerminalText.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getDictionaryEntries } from "@/utils/content";

const title = "About";
const terminalEntries = await getDictionaryEntries("terminal");
const educationEntries = terminalEntries.filter((entry) =>
    entry.id?.startsWith("education-"),
);
const experienceEntries = terminalEntries.filter(
    (entry) => !entry.id?.startsWith("education-"),
);
---

<BaseLayout title={title}>
    <div class="terminal-page terminal-subpage">
        <section
            class="terminal-section first-section"
            aria-labelledby="about-title"
        >
            <TerminalCommand command="cd about" />
            <TerminalHeading id="about-title" text="about.md" size="Small" />
            <p class="section-intro">
                Diese Seite ist für einen öffentlichen Fliesstext über mich
                vorbereitet. Der aktuelle Text ist ein Platzhalter.
            </p>

            <article class="about-copy">
                <TerminalText src="abouttext" />
            </article>

            <div class="terminal-list">
                <article class="terminal-entry">
                    <TerminalCommand path="/about" command="cat profile.yaml" />
                    <TerminalDictionary src="profile" />
                </article>

                <article class="terminal-entry">
                    <TerminalCommand path="/about" command="cat skills.yaml" />
                    <TerminalTable src="skills" />
                </article>

                {
                    educationEntries.map((entry) => (
                        <article class="terminal-entry">
                            <TerminalCommand
                                path="/about"
                                command={entry.command ?? "cat terminal.yaml"}
                            />
                            <TerminalDictionary src="terminal" entry={entry.id} />
                        </article>
                    ))
                }

                {
                    experienceEntries.map((entry) => (
                        <article class="terminal-entry">
                            <TerminalCommand
                                path="/about"
                                command={entry.command ?? "cat terminal.yaml"}
                            />
                            <TerminalDictionary src="terminal" entry={entry.id} />
                        </article>
                    ))
                }

                <article class="terminal-entry">
                    <TerminalCommand path="/about" command="cat languages.yaml" />
                    <TerminalList src="languages" />
                </article>

                <article class="terminal-entry">
                    <TerminalCommand path="/about" command="cat hobbies.yaml" />
                    <TerminalList src="hobbies" />
                </article>
            </div>
        </section>
    </div>
</BaseLayout>
