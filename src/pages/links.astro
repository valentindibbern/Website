---
import TerminalCommand from "@components/TerminalCommand.astro";
import TerminalHeading from "@components/TerminalHeading.astro";
import TerminalList from "@components/TerminalList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

const title = "Links";
---

<BaseLayout title={title}>
    <div class="terminal-page terminal-subpage">
        <section
            class="terminal-section first-section"
            aria-labelledby="links-title"
        >
            <TerminalCommand command="cd /links" />
            <TerminalHeading id="links-title" text="links.yaml" size="Small" />
            <p class="section-intro">
                Kontakt- und Profilrouten als statische Ausgabe. Die echten URLs
                können in den Markdown-Inhalten ersetzt werden.
            </p>

            <div class="terminal-list">
                <article class="terminal-entry">
                    <TerminalCommand path="/links" command="cat links.yaml" />
                    <TerminalList src="links" />
                </article>
            </div>
        </section>
    </div>
</BaseLayout>
