---
import TerminalCommand from "@components/TerminalCommand.astro";
import TerminalHeading from "@components/TerminalHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import TerminalDictionary from "@components/TerminalDictionary.astro";

const title = "Links";
---

<BaseLayout title={title}>
    <div class="terminal-page terminal-subpage">
        <section
            class="terminal-section first-section"
            aria-labelledby="links-title"
        >
            <TerminalCommand command="cd links" />
            <TerminalCommand command="echo $LINKS" path="links" />
            <TerminalHeading id="links-title" text="links" size="Small" />

            <div class="terminal-list">
                <article class="terminal-entry">
                    <TerminalCommand path="/links" command="cat links.yaml" />
                    <TerminalDictionary src="links" />
                </article>
            </div>
        </section>
    </div>
</BaseLayout>
