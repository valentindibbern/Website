---
import TerminalCommand from "@components/TerminalCommand.astro";
import TerminalDictionary from "@components/TerminalDictionary.astro";
import TerminalHeading from "@components/TerminalHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getDictionaryEntries } from "@/utils/content";

const title = "References";
const references = await getDictionaryEntries("references");
---

<BaseLayout title={title}>
    <div class="terminal-page terminal-subpage">
        <section
            class="terminal-section first-section"
            aria-labelledby="references-title"
        >
            <TerminalCommand command="cd /references" />
            <TerminalHeading id="references-title" text="references.md" size="Small" />
            <p class="section-intro">
                Referenzen und Dokumente als kuratiertes Terminal-Archiv. Die
                Inhalte bleiben bewusst ruhig und textbasiert.
            </p>

            <div class="terminal-list">
                {
                    references.map((entry) => (
                        <article class="terminal-entry">
                            <TerminalCommand
                                path="/references"
                                command={entry.command ?? "cat references.yaml"}
                            />
                            <TerminalDictionary
                                src="references"
                                entry={entry.id}
                            />
                        </article>
                    ))
                }
            </div>
        </section>
    </div>
</BaseLayout>
