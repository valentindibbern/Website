{
    "extends": "astro/tsconfigs/strict",
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"],
    "compilerOptions": {
        "jsx": "preserve",
        "paths": {
            "~/*": ["./src/*"],
            "@/*": ["./src/*"],
            "@components/*": ["./src/components/*"],
            "@layouts/*": ["./src/layouts/*"],
            "@/pages/*": ["./src/pages/*"],
            "@/styles/*": ["./src/styles/*"],
            "@/scripts/*": ["./src/scripts/*"],
        },
        "plugins": [
            {
                "name": "@astrojs/ts-plugin",
            },
        ],
    },
}
