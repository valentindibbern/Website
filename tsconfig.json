{
    "extends": "astro/tsconfigs/strict",
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"],
    "compilerOptions": {
        "jsx": "preserve",
        "paths": {
            "~/*": ["./src/*"],
            "@/*": ["./src/*"],
            "@components/*": ["./src/components/*"],
            "@layouts/*": ["./src/layouts/*"],
            "@pages/*": ["./src/pages/*"],
            "@styles/*": ["./src/styles/*"],
            "@scripts/*": ["./src/scripts/*"],
            "@assets/*": ["./src/assets/*"],
            "@config/*": ["./src/config/*"],
        },
        "plugins": [
            {
                "name": "@astrojs/ts-plugin",
            },
        ],
    },
}
